{
  "name": "superteam-academy",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "app",
    "backend",
    "runner"
  ],
  "scripts": {
    "lint": "pnpm -C app lint",
    "lint:console-guard": "pnpm -C app lint:console-guard",
    "typecheck": "pnpm -C app typecheck",
    "typecheck:backend": "pnpm -C backend typecheck",
    "test": "pnpm -C app test",
    "test:runner": "pnpm -C runner test",
    "build": "pnpm -C app build",
    "dev": "pnpm -C app dev",
    "dev:runner": "pnpm -C runner dev"
  },
  "pnpm": {
    "overrides": {
      "prismjs@<1.30.0": ">=1.30.0",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "valibot@>=0.31.0 <1.2.0": ">=1.2.0",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "undici@<6.23.0": ">=6.23.0",
      "bn.js@>=5.0.0 <5.2.3": ">=5.2.3",
      "bn.js@<4.12.3": ">=4.12.3",
      "minimatch@<3.1.4": ">=3.1.4",
      "minimatch@>=5.0.0 <5.1.8": ">=5.1.8",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "serialize-javascript@<=7.0.2": ">=7.0.3"
    }
  }
}
