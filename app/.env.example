# ============================================================================
# Superteam Academy - Environment Configuration
# ============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local or any file with real secrets to git
# ============================================================================

# ----------------------------------------------------------------------------
# Database (Required)
# ----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/superteam_academy

# ----------------------------------------------------------------------------
# NextAuth (Required)
# ----------------------------------------------------------------------------
# NextAuth configuration
NEXTAUTH_URL=http://localhost:3000
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-nextauth-key-min-32-chars

# ----------------------------------------------------------------------------
# OAuth Providers (Optional)
# ----------------------------------------------------------------------------
# Google OAuth - Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth - Get from https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ----------------------------------------------------------------------------
# Rate Limiting (Optional - Disabled by default)
# ----------------------------------------------------------------------------
# Set to "true" to enable rate limiting (requires Upstash Redis or in-memory)
RATE_LIMIT_ENABLED=false
# Upstash Redis REST API (optional - if not provided, uses in-memory store)
RATE_LIMIT_UPSTASH_REDIS_REST_URL=
RATE_LIMIT_UPSTASH_REDIS_REST_TOKEN=

# ----------------------------------------------------------------------------
# Logging (Optional)
# ----------------------------------------------------------------------------
# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Analytics (Optional)
# ----------------------------------------------------------------------------
# Google Analytics 4 - Get from https://analytics.google.com/analytics/web/
# Set NEXT_PUBLIC_GA_MEASUREMENT_ID to enable GA4 tracking
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# PostHog analytics + heatmaps (optional)
# Set NEXT_PUBLIC_POSTHOG_KEY to enable PostHog tracking
NEXT_PUBLIC_POSTHOG_KEY=
# Override only if using a self-hosted PostHog instance
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry Error Monitoring - Get from https://sentry.io/settings/projects/
# Set NEXT_PUBLIC_SENTRY_DSN to enable error tracking
NEXT_PUBLIC_SENTRY_DSN=

# Legacy analytics flags (deprecated, use above instead)
ANALYTICS_ENABLED=false
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# ----------------------------------------------------------------------------
# Public App URL (Optional)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Sanity CMS (Optional - Required when CONTENT_SOURCE=sanity)
# ----------------------------------------------------------------------------
# Public read configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01

# Server-side write token (required for sanity import script)
SANITY_API_TOKEN=

# ----------------------------------------------------------------------------
# Solana Configuration (Optional)
# ----------------------------------------------------------------------------
# Solana RPC endpoint for wallet adapter and on-chain reads
# Defaults to devnet if not specified
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Superteam Academy program on Solana devnet
# Current repo default: ACADBRCB3zGvo1KSCbkztS33ZNzeBv2d7bqGceti3ucf
NEXT_PUBLIC_SUPERTEAM_ACADEMY_PROGRAM_ID=ACADBRCB3zGvo1KSCbkztS33ZNzeBv2d7bqGceti3ucf

# XP Token Mint Address on devnet
# Current repo default: xpXPUjkfk7t4AJF1tYUoyAYxzuM5DhinZWS1WjfjAu3
NEXT_PUBLIC_XP_MINT_ADDRESS=xpXPUjkfk7t4AJF1tYUoyAYxzuM5DhinZWS1WjfjAu3

# Credential Collection Address (Optional)
# The collection address for Superteam Academy credentials on devnet
# Leave empty until the collection mint/group address is confirmed
NEXT_PUBLIC_CREDENTIAL_COLLECTION_ADDRESS=

# ----------------------------------------------------------------------------
# Helius API (Optional)
# ----------------------------------------------------------------------------
# Helius API key for DAS (Digital Asset Standard) API access
# Required for fetching cNFT credentials from devnet
# Get your API key at: https://helius.xyz
HELIUS_API_KEY=

# ----------------------------------------------------------------------------
# Node Environment (Set by Next.js)
# ----------------------------------------------------------------------------
NODE_ENV=development

# ----------------------------------------------------------------------------
# Runner Service (Playground real terminal)
# ----------------------------------------------------------------------------
# URL of external runner service (docker-compose default shown)
RUNNER_URL=http://localhost:8787
# Shared secret used for HMAC-signing runner job submissions
# Must match RUNNER_SHARED_SECRET in docker-compose/runner environment
RUNNER_SHARED_SECRET=change-me-local-secret

# ----------------------------------------------------------------------------
# Content and Proxy Behavior (Optional)
# ----------------------------------------------------------------------------
# "local" = embedded course files, "sanity" = headless CMS runtime
CONTENT_SOURCE=local
# Set to "true" only when you intentionally trust generic X-Forwarded-For/X-Real-IP headers
TRUST_PROXY_HEADERS=false
