{
  "ignorePatterns": ["public/monaco-editor/**"],
  "extends": ["next/core-web-vitals"],
  "overrides": [
    {
      "files": ["tests/**/*.{ts,tsx}"],
      "rules": {
        "@next/next/no-assign-module-variable": "off",
        "react/no-children-prop": "off"
      }
    },
    {
      "files": ["src/app/api/**/*.ts", "src/lib/**/*.{ts,tsx}"],
      "excludedFiles": [
        "src/lib/analytics/**",
        "src/lib/courses/**",
        "src/lib/data/**",
        "src/lib/devlab/**",
        "src/lib/env.ts",
        "src/lib/playground/**",
        "src/lib/workbench/**",
        "src/lib/workspace/**"
      ],
      "rules": {
        "no-console": "error"
      }
    }
  ]
}
